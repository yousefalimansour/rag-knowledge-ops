# ─── api ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-prod-please
DATABASE_URL=postgresql+asyncpg://kops:kops@db:5432/kops
REDIS_URL=redis://cache:6379/0
CHROMA_URL=http://vector:8000
CORS_ORIGINS=http://localhost:7000

# ─── auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=60
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ─── google ai studio ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# ─── limits ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=25
RATE_LIMIT_PER_MIN=60
QUERY_RATE_LIMIT_PER_MIN=20
LOGIN_RATE_LIMIT_PER_15MIN=5

# ─── celery beat schedules ────────────────────────────────────────────────────
INSIGHT_COORDINATOR_CRON=*/30 * * * *
INSIGHT_NIGHTLY_AUDIT_CRON=0 3 * * *

# ─── web ──────────────────────────────────────────────────────────────────────
# Used by `next dev` running on the host (outside docker). Inside the web
# container, docker-compose hard-overrides this to http://api:8000 (DNS).
NEXT_PUBLIC_API_URL=http://localhost:8090
