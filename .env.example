# ─── api ──────────────────────────────────────────────────────────────────────
# `production` enables COOKIE_SECURE=true, hides /docs, and refuses to start
# with placeholder values for SECRET_KEY / JWT_SECRET / GOOGLE_API_KEY.
APP_ENV=development

# Used internally for any non-JWT cryptographic operation we add later. Must
# differ from JWT_SECRET in prod. 32+ chars of randomness recommended.
SECRET_KEY=change-me-in-prod-please

# Postgres async URL. Compose injects an internal hostname (`db`).
DATABASE_URL=postgresql+asyncpg://kops:kops@db:5432/kops

# Redis is broker + cache + rate-limit store. Container-internal hostname.
REDIS_URL=redis://cache:6379/0

# Chroma's HTTP API. Container-internal hostname; exposed on host port 8001.
CHROMA_URL=http://vector:8000

# Comma-separated origins allowed for browser CORS. Credentials are enabled,
# so this MUST list explicit origins — never `*`.
CORS_ORIGINS=http://localhost:7000

# ─── auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret. Rotate by deploying a new value (existing tokens become
# invalid and users re-login).
JWT_SECRET=change-me-jwt-secret-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=60
REFRESH_TOKEN_TTL_DAYS=14

# Set to `true` in production (HTTPS only). Stays `false` in dev so the demo
# works at http://localhost.
COOKIE_SECURE=false

# Empty = no domain attribute (browser uses request host). Required for
# cross-subdomain cookie sharing in prod.
COOKIE_DOMAIN=

# ─── google ai studio ─────────────────────────────────────────────────────────
# Get one at https://aistudio.google.com/apikey . Free tier is enough for the
# demo. Boot fails if APP_ENV=production and this is empty.
GOOGLE_API_KEY=

# Generation model. `gemini-2.5-flash` is the default — high free-tier quota
# and adequate quality. `gemini-2.5-pro` exists but free tier is 0 RPM.
GEMINI_MODEL=gemini-2.5-flash

# Embedding model. `gemini-embedding-001` is the active free-tier model
# (`text-embedding-004` was removed). Native dim is 3072; we truncate to
# EMBEDDING_DIM via the Matryoshka representation.
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768

# ─── limits ───────────────────────────────────────────────────────────────────
# Per-file upload cap. Files stream to disk — no full buffer in memory.
MAX_UPLOAD_MB=25

# Per-IP per-minute rate limit for write / ingest endpoints.
RATE_LIMIT_PER_MIN=60

# Stricter limit for the LLM endpoints — protects free-tier Gemini quota.
QUERY_RATE_LIMIT_PER_MIN=20

# Login attempts per 15 minutes per IP — defends against credential-stuffing.
LOGIN_RATE_LIMIT_PER_15MIN=5

# ─── celery beat schedules ────────────────────────────────────────────────────
# Coordinator: scans changes since the last watermark. Cron: m h dom mon dow.
INSIGHT_COORDINATOR_CRON=*/30 * * * *

# Nightly audit: full conflict + repeated-decision + stale-document scan.
INSIGHT_NIGHTLY_AUDIT_CRON=0 3 * * *

# ─── web ──────────────────────────────────────────────────────────────────────
# Used by `next dev` running on the host (outside docker). Inside the web
# container, docker-compose hard-overrides this to http://api:8000 (DNS).
NEXT_PUBLIC_API_URL=http://localhost:8090
